# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Plugin dependencies
plugin/npm/*/node_modules/
plugin/lambda/*/node_modules/

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
/dist

# Plugin build outputs
plugin/npm/*/dist/
plugin/npm/*/build/
plugin/lambda/*/dist/

# Lambda deployment packages
*.zip
plugin/lambda/*/*.zip

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Plugin lock files (keep package.json but not lock files)
plugin/npm/*/package-lock.json
plugin/lambda/*/package-lock.json

# Development files
ANALYTICS_PACKAGE_PLAN.md
PLUGIN_INTEGRATION_GUIDE.md
ANALYTICS_TESTING_SUMMARY.md

# IDE files
.vscode/
.idea/
*.swp
*.swo


CLAUDE.md
ANALYTICS_PACKAGE_PLAN.md
DEPLOYMENT_GUIDE.md
validate-deployment.sh