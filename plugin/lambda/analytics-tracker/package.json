{
  "name": "clickchutney-analytics-tracker",
  "version": "1.0.0",
  "description": "AWS Lambda function for ClickChutney analytics event tracking",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=esm --outfile=dist/index.js",
    "package": "npm run build && zip -r analytics-tracker.zip dist/ package.json",
    "zip": "zip -r analytics-tracker.zip . -x '*.zip' '.git/*' 'README.md' 'deploy.sh'",
    "deploy": "aws lambda update-function-code --function-name clickchutney-analytics --zip-file fileb://analytics-tracker.zip",
    "test": "jest",
    "dev": "nodemon --exec node --loader ts-node/esm src/index.ts"
  },
  "dependencies": {
    "aws-lambda": "^1.0.7",
    "dotenv": "^17.2.1",
    "mongodb": "^6.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.131",
    "@types/node": "^20.10.4",
    "esbuild": "^0.19.8",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
